{
  "$schema": "https://json.schemastore.org/env.json",
  "type": "object",
  "properties": {
    "NEXT_PUBLIC_SUPABASE_URL": {
      "type": "string",
      "description": "Your Supabase project URL from Settings → API",
      "examples": ["https://xxxxx.supabase.co"]
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "type": "string",
      "description": "Your Supabase anonymous public key from Settings → API"
    },
    "NEXT_PUBLIC_FORMSPREE_ID": {
      "type": "string",
      "description": "Your Formspree form ID for email notifications",
      "examples": ["xxxxxxxxx"]
    }
  },
  "required": ["NEXT_PUBLIC_SUPABASE_URL", "NEXT_PUBLIC_SUPABASE_ANON_KEY", "NEXT_PUBLIC_FORMSPREE_ID"]
}
